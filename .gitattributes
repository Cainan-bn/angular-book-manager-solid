# =============================================================
#  .gitattributes — Catálogo de Livros
#
#  Garante quebras de linha consistentes entre Windows, macOS
#  e Linux. Sem isso, o Git pode marcar arquivos inteiros como
#  "modificados" apenas por diferença de CRLF vs LF, poluindo
#  o histórico de commits.
# =============================================================

# Comportamento padrão: normaliza todos os arquivos de texto
*                   text=auto eol=lf

# ─── Código-fonte TypeScript / JavaScript ───────────────────
*.ts                text eol=lf
*.tsx               text eol=lf
*.js                text eol=lf
*.jsx               text eol=lf
*.mjs               text eol=lf
*.cjs               text eol=lf

# ─── Markup e estilo ────────────────────────────────────────
*.html              text eol=lf
*.css               text eol=lf
*.scss              text eol=lf
*.sass              text eol=lf
*.less              text eol=lf

# ─── Dados e configuração ───────────────────────────────────
*.json              text eol=lf
*.jsonc             text eol=lf
*.yaml              text eol=lf
*.yml               text eol=lf
*.toml              text eol=lf
*.xml               text eol=lf
*.svg               text eol=lf

# ─── Documentação ───────────────────────────────────────────
*.md                text eol=lf
*.txt               text eol=lf
*.rst               text eol=lf
LICENSE             text eol=lf

# ─── Scripts ────────────────────────────────────────────────
*.sh                text eol=lf
*.bash              text eol=lf
*.zsh               text eol=lf

# Batch scripts precisam de CRLF no Windows
*.bat               text eol=crlf
*.cmd               text eol=crlf
*.ps1               text eol=crlf

# ─── Binários — nunca processar como texto ──────────────────
*.png               binary
*.jpg               binary
*.jpeg              binary
*.gif               binary
*.ico               binary
*.webp              binary
*.woff              binary
*.woff2             binary
*.ttf               binary
*.eot               binary
*.otf               binary
*.pdf               binary
*.zip               binary
*.tar               binary
*.gz                binary
*.7z                binary
